#!/bin/bash

if [[ $# -eq 1 ]]; then
  selected=$1
else
  selected=$(find ~/.dotfiles/.config/ ~/.dotfiles/ ~/.dotfiles/.local ~/hyprland/ ~/hyprland/.config -mindepth 1 -maxdepth 1 -type d -not -path '*/.git*' | fzf --layout=reverse --border)
fi

if [[ -z $selected ]]; then
  exit 0
fi

selected_name=$(basename "$selected" | tr . _)
tmux_running=$(pgrep tmux)

# If not in a tmux session and tmux is not running, create a new session and attach
if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
  tmux new-session -s $selected_name -c $selected
  exit 0
fi

# Check if a window with the same name exists globally
if tmux list-windows -a | grep -q ": $selected_name"; then
  # If the window exists, switch to it
  session_window=$(tmux list-windows -a | grep ": $selected_name" | awk -F: '{print $1 ":" $2}')
  tmux switch-client -t "$session_window"
else
  # If the window does not exist, create a new window
  if [[ -n $TMUX ]]; then
    tmux new-window -n "$selected_name" -c "$selected" "nvim ."
  else
    # If not in tmux, attach to the session and create a new window
    if tmux has-session -t=$selected_name 2>/dev/null; then
      tmux attach-session -t $selected_name \; new-window -n "$selected_name" -c "$selected" "nvim ."
    else
      tmux new-session -s $selected_name -c "$selected" \; rename-window "$selected_name" \; send-keys "nvim ." C-m
    fi
  fi
fi
